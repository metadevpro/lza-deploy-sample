{
  "plans": {
    "Daily": {
      "regions": {
        "@@append": [
          "eu-west-1"
        ]
      },
      "rules": {
        "Backup_Rule": {
          "schedule_expression": {
            "@@assign": "cron(0 5 ? * * *)"
          },
          "lifecycle": {
            "delete_after_days": {
              "@@assign": "7"
            }
          },
          "target_backup_vault_name": {
            "@@assign": "BackupVault"
          }
        }
      },
      "selections": {
        "tags": {
          "Backup_Assignment": {
            "iam_role_arn": {
              "@@assign": "arn:aws:iam::$account:role/Backup-Role"
            },
            "tag_key": {
              "@@assign": "BackupPlan"
            },
            "tag_value": {
              "@@assign": [
                "Daily"
              ]
            }
          }
        }
      }
    },
    "Weekly": {
      "regions": {
        "@@append": [
          "eu-west-1"
        ]
      },
      "rules": {
        "Backup_Rule": {
          "schedule_expression": {
            "@@assign": "cron(30 1 ? * 7 *)"
          },
          "lifecycle": {
            "delete_after_days": {
              "@@assign": "35"
            }
          },
          "target_backup_vault_name": {
            "@@assign": "BackupVault"
          }
        }
      },
      "selections": {
        "tags": {
          "Backup_Assignment": {
            "iam_role_arn": {
              "@@assign": "arn:aws:iam::$account:role/Backup-Role"
            },
            "tag_key": {
              "@@assign": "BackupPlan"
            },
            "tag_value": {
              "@@assign": [
                "Weekly"
              ]
            }
          }
        }
      }
    },
    "Monthly": {
      "regions": {
        "@@append": [
          "eu-west-1"
        ]
      },
      "rules": {
        "Backup_Rule": {
          "schedule_expression": {
            "@@assign": "cron(0 5 1 * ? *)"
          },
          "lifecycle": {
            "move_to_cold_storage_after_days": {
              "@@assign": "7"
            },
            "delete_after_days": {
              "@@assign": "361"
            }
          },
          "target_backup_vault_name": {
            "@@assign": "BackupVault"
          }
        }
      },
      "selections": {
        "tags": {
          "Backup_Assignment": {
            "iam_role_arn": {
              "@@assign": "arn:aws:iam::$account:role/Backup-Role"
            },
            "tag_key": {
              "@@assign": "BackupPlan"
            },
            "tag_value": {
              "@@assign": [
                "Monthly"
              ]
            }
          }
        }
      }
    }
  }
}